Rule 6     statement -> define_macro
Rule 7     statement -> macro_call
Rule 8     imports_statement -> IMPORTS LCURLY import_list RCURLY
Rule 9     import_list -> import_list import_item
Rule 10    import_list -> import_item
Rule 11    import_item -> IDENTIFIER
Rule 12    define_block -> DEFINE LCURLY variable_list RCURLY
Rule 13    optional_flag -> IDENTIFIER
Rule 14    optional_flag -> empty
Rule 15    variable_list -> variable_list variable_definition
Rule 16    variable_list -> variable_definition
Rule 17    variable_definition -> IDENTIFIER EQUALS value flag_list_opt
Rule 18    flag_list_opt -> LBRACKET flag_list RBRACKET
Rule 19    flag_list_opt -> empty
Rule 20    flag_list -> flag_list COMMA IDENTIFIER
Rule 21    flag_list -> flag_list IDENTIFIER
Rule 22    flag_list -> IDENTIFIER
Rule 23    define_macro -> DEFINE_MACRO IDENTIFIER LPAREN macro_params RPAREN LCURLY macro_body RCURLY
Rule 24    macro_body -> macro_body ANY_TEXT
Rule 25    macro_body -> ANY_TEXT
Rule 26    macro_params -> macro_params COMMA DOLLAR_IDENTIFIER
Rule 27    macro_params -> DOLLAR_IDENTIFIER
Rule 28    macro_params -> empty
Rule 29    macro_call -> MACRO IDENTIFIER LPAREN macro_args RPAREN
Rule 30    macro_args -> macro_args COMMA value
Rule 31    macro_args -> value
Rule 32    macro_args -> empty
Rule 33    value -> STRING
Rule 34    value -> NUMBER
Rule 35    value -> IDENTIFIER
Rule 36    value -> DOLLAR_IDENTIFIER
Rule 37    empty -> <empty>

